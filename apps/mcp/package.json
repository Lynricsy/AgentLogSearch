{
  "name": "mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent-log-search-mcp": "./dist/main.js"
  },
  "exports": {
    "./api-client": {
      "types": "./src/api-client.ts",
      "import": "./dist/api-client.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @agent-log-search/shared build && tsc -p tsconfig.build.json",
    "dev": "tsx src/main.ts",
    "lint": "biome check .",
    "smoke:stdio": "node --enable-source-maps dist/stdio-smoke.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-log-search/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ky": "^2.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "tsx": "^4.22.4",
    "vitest": "3.2.4"
  }
}
