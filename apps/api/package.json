{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter mcp build && tsc -p tsconfig.build.json",
    "dev": "nest start --watch --tsc -p tsconfig.build.json",
    "start": "node --enable-source-maps dist/main.js",
    "start:dev": "nest start --watch --tsc -p tsconfig.build.json",
    "lint": "biome check .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "evaluate:experience-search": "tsx scripts/evaluate-experience-search.ts",
    "inspect:fixtures": "tsx scripts/inspect-agent-fixtures.ts ../../sample-data --output ../../docs/evidence/fixture-shape-inventory.json && cd ../.. && biome format --write docs/evidence/fixture-shape-inventory.json",
    "test": "jest --config jest.config.cjs --passWithNoTests",
    "test:e2e": "jest --config test/jest-e2e.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@agent-log-search/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/client": "^6.19.3",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tree-sitter": "^0.21.1",
    "mcp": "workspace:*",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "25.9.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "prisma": "^6.19.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4"
  }
}
