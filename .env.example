NODE_ENV=development

# PostgreSQL
POSTGRES_DB=agent_log_search
POSTGRES_USER=agent_log_search
POSTGRES_PASSWORD=agent_log_search
# 仅本机源码开发使用 docker-compose.dev.yml 时会发布这个数据库端口。
POSTGRES_PORT=5432
DATABASE_URL=postgresql://agent_log_search:agent_log_search@localhost:5432/agent_log_search

# API，本机源码开发时供 Web 反代访问；Docker demo 中 API 不发布宿主端口。
API_HOST=127.0.0.1
API_PORT=3001

# Web，Docker demo 唯一发布到宿主机的应用端口。
WEB_PORT=3000

# 浏览器默认使用同源 /api；Next rewrite 会代理到 API_PROXY_TARGET。
API_PROXY_TARGET=http://localhost:3001
# 可选调试项：设置后浏览器会绕过 Web 反代直连 API，不属于单端口模式。
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Embedding provider.
# 源码开发默认使用 mock；Docker demo 会在 compose 内覆盖为 ollama。
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=qwen3-embedding:8b-q4_K_M
EMBEDDING_DIMENSION=1024
EMBEDDING_PROCESS_BATCH_SIZE=16
EMBEDDING_OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_OLLAMA_KEEP_ALIVE=30m
EMBEDDING_OLLAMA_TIMEOUT_MS=120000
EMBEDDING_OLLAMA_NUM_PARALLEL=2
EMBEDDING_OLLAMA_MAX_LOADED_MODELS=1
EMBEDDING_WORKER_ENABLED=true
EMBEDDING_WORKER_INTERVAL_MS=5000
EMBEDDING_WORKER_STALE_PROCESSING_MS=900000
# 可选：只让后台 worker 处理某一个 sourceId。留空表示处理全部待处理 chunk。
EMBEDDING_WORKER_SOURCE_ID=
OLLAMA_IMAGE=ollama/ollama:latest

# Scanner scheduler
SCAN_SCHEDULER_ENABLED=false
SCAN_INTERVAL_SECONDS=60
SCANNER_IMPORT_TRANSACTION_TIMEOUT_MS=120000

# Evidence Edition MVP 开关。
# M0 阶段默认关闭证据旁路流水线；只在聚焦测试或后续 demo 里显式开启。
EVIDENCE_PIPELINE_ENABLED=false
EXPERIENCE_WORKER_ENABLED=false
EXPERIENCE_SEARCH_ENABLED=false
REPOSITORY_COMPATIBILITY_ENABLED=false

EVIDENCE_MAX_TOOL_OUTPUT_CHARS=2000000
EVIDENCE_MAX_EXCERPT_CHARS=2000
EVIDENCE_MAX_ERRORS_PER_EVENT=20
EVIDENCE_MAX_PATHS_PER_EVENT=100

EXPERIENCE_WORKER_INTERVAL_MS=3000
EXPERIENCE_WORKER_BATCH_SIZE=8
EXPERIENCE_WORKER_STALE_PROCESSING_MS=900000

# Source/path limit documentation.
# 这些限制对应 source 创建/更新请求字段，不是全局运行时 env 开关。
SOURCE_SCAN_INTERVAL_SECONDS=300
SOURCE_MAX_FILE_SIZE_BYTES=5242880
SOURCE_MAX_FILES_PER_SCAN=1000
SOURCE_FOLLOW_SYMLINKS=false

# Docker demo 可选真实历史只读 bind mount。默认保持注释，让 demo 使用 sample-data。
# CODEX_HISTORY_HOST_PATH=/home/you/.codex/sessions
# CLAUDE_HISTORY_HOST_PATH=/home/you/.claude/projects
# PI_HISTORY_HOST_PATH=/home/you/.pi/agent/sessions
# OPENCODE_HISTORY_HOST_PATH=/home/you/.local/share/opencode
