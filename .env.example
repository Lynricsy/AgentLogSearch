NODE_ENV=development
DATABASE_URL=postgresql://agent_log_search:agent_log_search@localhost:5432/agent_log_search
API_HOST=127.0.0.1
API_PORT=3001
WEB_PORT=3000

# Web 默认使用相对 /api；Next rewrite 会代理到 API_PROXY_TARGET。
API_PROXY_TARGET=http://localhost:3001
# 可选：仅在本地开发需要浏览器直连 API 时设置；直连需要 API CORS 允许且仍保持仅本机使用。
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

CODEX_HISTORY_HOST_PATH=~/.codex/sessions
CLAUDE_HISTORY_HOST_PATH=~/.claude/projects
PI_HISTORY_HOST_PATH=~/.pi/agent/sessions
OPENCODE_HISTORY_HOST_PATH=~/.local/share/opencode
