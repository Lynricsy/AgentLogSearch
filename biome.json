{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!**/node_modules",
      "!dist",
      "!**/dist",
      "!build",
      "!**/build",
      "!.next",
      "!**/.next",
      "!coverage",
      "!**/coverage",
      "!.playwright-mcp",
      "!**/.playwright-mcp",
      "!apps/web/next-env.d.ts",
      "!pnpm-lock.yaml",
      "!.omo/evidence",
      "!AgentLogs"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noBannedTypes": "error"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "noDefaultExport": "off",
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "useImportType": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noFallthroughSwitchClause": "error"
      }
    }
  }
}
